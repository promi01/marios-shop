# Marios Shop — local environment template
#
# Copy this file to `.env.local` (which is gitignored) and fill in real values
# before running `npm run dev`. The same values must also be set on Vercel
# (Project → Settings → Environment Variables).
#
# ─────────────────────────────────────────────────────────────────────────
# Admin authentication
# ─────────────────────────────────────────────────────────────────────────

# The password you type at /admin/login.
# Choose something long and unique. Anyone with this password can edit
# inventory and upload photos.
ADMIN_PASSWORD=change-me

# Secret used to sign the admin session cookie. MUST be at least 16 chars.
# Generate one with: openssl rand -base64 32
# (Or use any random ≥16 char string — the only requirement is secrecy.)
ADMIN_JWT_SECRET=replace-with-32-random-chars-min

# ─────────────────────────────────────────────────────────────────────────
# Vercel Blob storage (set automatically on Vercel; required locally only
# if you want to test admin writes/uploads against real Blob)
# ─────────────────────────────────────────────────────────────────────────
#
# When deployed on Vercel with Blob enabled, this is injected at runtime —
# do NOT add it to your Vercel env vars manually. The CLI command
#   vercel env pull .env.local
# will populate this for local testing.
#
# Without this token set, the site falls back to reading data/inventory.json
# (read-only) so dev still works without Blob configured.
# BLOB_READ_WRITE_TOKEN=
